{
  "openapi": "3.0.0",
  "info": {
    "title": "SI-ALAT API Documentation",
    "version": "1.0.0",
    "description": "Dokumentasi API Sistem Informasi & Peminjaman Alat Lab FIK"
  },
  "servers": [
    {
      "url": "http://localhost:3000/api",
      "description": "Server Lokal Aplikasi (Next.js)"
    },
    {
      "url": "http://localhost:9080/api",
      "description": "Server APISIX Gateway (Proxy)"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "User Login",
        "description": "Melakukan login untuk mendapatkan token JWT",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "example": "admin@sialat.ac.id"
                  },
                  "password": { "type": "string", "example": "admin123" }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login berhasil dan mengembalikan token" },
          "401": { "description": "Email atau password salah" }
        }
      }
    },
    "/peralatan": {
      "get": {
        "summary": "Mendapatkan Daftar Peralatan",
        "description": "Mengambil semua data peralatan lab (Butuh Token Bearer)",
        "responses": {
          "200": { "description": "Berhasil mengambil data peralatan" },
          "401": { "description": "Unauthorized (Token tidak valid/tidak ada)" }
        }
      }
    }
  }
}
