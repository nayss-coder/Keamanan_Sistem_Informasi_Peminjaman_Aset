{
  "openapi": "3.0.0",
  "info": {
    "title": "SI-ALAT API Documentation",
    "version": "1.0.0",
    "description": "Dokumentasi API Sistem Informasi & Peminjaman Alat Lab FIK"
  },
  "servers": [
    {
      "url": "/api",
      "description": "Base API Path"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "summary": "User Login",
        "description": "Melakukan autentikasi menggunakan email dan password untuk mendapatkan token JWT. Berlaku untuk seluruh role pengguna (Admin, Dosen PJ, Laboran, Mahasiswa).",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["email", "password"]
              },
              "examples": {
                "admin": {
                  "summary": "Login Admin",
                  "value": {
                    "email": "admin@sialat.ac.id",
                    "password": "admin123"
                  }
                },
                "dosen": {
                  "summary": "Login Dosen PJ",
                  "value": {
                    "email": "budi@sialat.ac.id",
                    "password": "dosen123"
                  }
                },
                "laboran": {
                  "summary": "Login Laboran",
                  "value": {
                    "email": "rini@sialat.ac.id",
                    "password": "laboran123"
                  }
                },
                "mahasiswa": {
                  "summary": "Login Mahasiswa",
                  "value": {
                    "email": "andi@student.ac.id",
                    "password": "mhs123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login berhasil dan mengembalikan token JWT." },
          "401": { "description": "Email atau password salah." },
          "400": { "description": "Field email/password tidak lengkap." }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "User Logout",
        "description": "Menghapus cookie token autentikasi sesi aktif.",
        "responses": {
          "200": { "description": "Logout berhasil." }
        }
      }
    },
    "/auth/me": {
      "get": {
        "summary": "Get Current User Profile",
        "description": "Mengambil informasi detail profil user yang sedang login berdasarkan token.",
        "responses": {
          "200": { "description": "Informasi profil berhasil diambil." },
          "401": { "description": "Unauthorized / Token tidak valid." }
        }
      }
    },
    "/peralatan": {
      "get": {
        "summary": "Mendapatkan Daftar Peralatan",
        "description": "Mengambil data semua peralatan lab dengan filter pencarian, kategori, dan status.",
        "parameters": [
          { "name": "q", "in": "query", "description": "Kata kunci pencarian nama atau kode alat", "schema": { "type": "string" } },
          { "name": "kategori", "in": "query", "description": "Filter berdasarkan kategori", "schema": { "type": "string" } },
          { "name": "status", "in": "query", "description": "Filter berdasarkan status", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Data peralatan berhasil diambil." },
          "401": { "description": "Unauthorized." }
        }
      },
      "post": {
        "summary": "Menambahkan Peralatan Baru",
        "description": "Menambah alat baru ke database (Hanya boleh diakses oleh Admin atau Laboran).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "kode": { "type": "string", "example": "ALT-011" },
                  "nama": { "type": "string", "example": "Multimeter Digital" },
                  "kategori": { "type": "string", "example": "Elektronika" },
                  "lokasi": { "type": "string", "example": "Lab 102" },
                  "deskripsi": { "type": "string", "example": "Alat pengukur listrik portable" },
                  "jumlah": { "type": "integer", "example": 5 }
                },
                "required": ["kode", "nama", "kategori", "lokasi"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Peralatan berhasil ditambahkan." },
          "400": { "description": "Field wajib tidak lengkap." },
          "403": { "description": "Forbidden: Hanya laboran/admin." }
        }
      }
    },
    "/peminjaman": {
      "get": {
        "summary": "Mendapatkan Daftar Peminjaman",
        "description": "Mengambil data riwayat peminjaman. Mahasiswa hanya melihat data milik mereka, sedangkan Admin/Dosen melihat semua data.",
        "responses": {
          "200": { "description": "Data peminjaman berhasil diambil." }
        }
      },
      "post": {
        "summary": "Mengajukan Permohonan Peminjaman",
        "description": "Membuat pengajuan peminjaman alat lab baru.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "peralatan_id": { "type": "integer", "example": 1 },
                  "jumlah": { "type": "integer", "example": 1 },
                  "tanggal_pinjam": { "type": "string", "format": "date", "example": "2026-07-01" },
                  "tanggal_kembali": { "type": "string", "format": "date", "example": "2026-07-03" },
                  "keperluan": { "type": "string", "example": "Tugas Praktikum" }
                },
                "required": ["peralatan_id", "tanggal_pinjam", "tanggal_kembali", "keperluan"]
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Permohonan peminjaman berhasil dibuat." },
          "409": { "description": "Stok peralatan tidak mencukupi." }
        }
      }
    },
    "/peminjaman/{id}": {
      "patch": {
        "summary": "Persetujuan / Pengembalian Peminjaman",
        "description": "Melakukan tindakan persetujuan (approve/reject oleh Dosen/Admin) atau pengembalian (return oleh siapa saja).",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": { "type": "string", "enum": ["approve", "reject", "return"], "example": "approve" },
                  "catatan": { "type": "string", "example": "Disetujui untuk praktikum" }
                },
                "required": ["action"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Tindakan berhasil diproses." }
        }
      }
    },
    "/admin/users": {
      "get": {
        "summary": "Mendapatkan Daftar Semua User",
        "description": "Mengambil semua daftar user terdaftar di sistem (Hanya untuk Admin).",
        "responses": {
          "200": { "description": "Berhasil mengambil daftar user." },
          "403": { "description": "Forbidden: Hanya admin." }
        }
      }
    },
    "/admin/stats": {
      "get": {
        "summary": "Mendapatkan Statistik Dashboard",
        "description": "Mengambil ringkasan jumlah alat, ketersediaan, peminjaman aktif, dan menunggu approval (Hanya untuk Admin).",
        "responses": {
          "200": { "description": "Berhasil mengambil statistik." }
        }
      }
    }
  }
}
